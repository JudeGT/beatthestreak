# Project DiMaggio — Environment Variables
# Copy this file to .env and fill in your keys

# OpenWeatherMap API Key (https://openweathermap.org/api)
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# DuckDB database path (relative to project root)
DUCKDB_PATH=data/dimaggio.duckdb

# Directory for raw Bronze Parquet/CSV files
BRONZE_DATA_DIR=data/bronze

# Directory for trained model checkpoints
MODEL_CHECKPOINT_DIR=models/checkpoints

# Optional: override logging level (DEBUG, INFO, WARNING)
LOG_LEVEL=INFO
